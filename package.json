{
    "name": "happy-place",
    "version": "0.0.1",
    "description": "Happy place",
    "author": "Mark Jivko",
    "type": "commonjs",
    "private": true,
    "scripts": {
        "format": "prettier --write \"{src,test}/**/*.{css,js,php,html,md}\"",
