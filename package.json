        "eslint-config-google": "0.14.0",
        "eslint-config-prettier": "8.10.0",
        "eslint-import-resolver-alias": "1.1.2",
        "eslint-plugin-import": "2.32.0",
        "eslint-plugin-prettier": "4.2.1",
        "eslint-plugin-unused-imports": "2.0.0",
        "jest": "28.1.3",
        "jest-junit": "15.0.0",
        "prettier": "2.8.8",
        "prompts": "^2.4.2"
